{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true
  },
  "agents": {
    "sisyphus": {
      "model": "vercel/moonshotai/kimi-k2.5",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "vercel/zai/glm-4.7",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "explore": {
      "model": "vercel/xai/grok-code-fast-1",
      "fallback_models": [
        "github-copilot/grok-code-fast-1",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "multimodal-looker": {
      "model": "vercel/google/gemini-3-flash",
      "fallback_models": [
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "prometheus": {
      "model": "vercel/anthropic/claude-opus-4.6",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "openai/gpt-5.3-codex"
      ],
      "variant": "max"
    },
    "metis": {
      "model": "vercel/anthropic/claude-opus-4.6",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "openai/gpt-5.3-codex"
      ],
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "atlas": {
      "model": "vercel/anthropic/claude-sonnet-4.5",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "openai/gpt-5.3-codex"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "vercel/google/gemini-3-pro-preview",
      "fallback_models": [
        "github-copilot/gemini-3-pro-preview",
        "openai/gpt-5.3-codex"
      ],
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "artistry": {
      "model": "vercel/google/gemini-3-pro-preview",
      "fallback_models": [
        "github-copilot/gemini-3-pro-preview",
        "openai/gpt-5.3-codex"
      ],
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.3-codex-spark",
      "description": "Simple tasks with clear instructions: typo fixes, applying given changes across a few files, straightforward modifications. Not suited for tasks requiring deep context understanding or exploratory reasoning. This model has a relatively small context window.",
      "prompt_append": "You have a relatively small context window. Avoid reading files unless necessary for the task. Focus on the specific files and locations given, and make the changes as directed."
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "writing": {
      "model": "vercel/moonshotai/kimi-k2.5",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    }
  },
  "git_master": {
    "include_co_authored_by": false
  }
}

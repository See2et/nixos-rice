{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "model": "vercel/moonshotai/kimi-k2.5",
  "agent": {
    "sisyphus": {
      "description": "Default coding agent with kimi-k2.5",
      "model": "vercel/moonshotai/kimi-k2.5",
      "mode": "primary"
    },
    "hephaestus": {
      "description": "Implementation-focused coding agent",
      "model": "openai/gpt-5.3-codex",
      "mode": "primary"
    },
    "oracle": {
      "description": "Deep architecture and decision support",
      "model": "openai/gpt-5.4",
      "mode": "primary"
    },
    "librarian": {
      "description": "Research and reference-heavy tasks",
      "model": "vercel/zai/glm-4.7",
      "mode": "primary"
    },
    "multimodal-looker": {
      "description": "Multimodal inspection tasks",
      "model": "vercel/google/gemini-3-flash",
      "mode": "primary"
    },
    "prometheus": {
      "description": "Maximum-depth reasoning",
      "model": "vercel/anthropic/claude-opus-4.6",
      "mode": "primary"
    },
    "metis": {
      "description": "Analytical strategy and planning",
      "model": "vercel/anthropic/claude-opus-4.6",
      "mode": "primary"
    },
    "momus": {
      "description": "Balanced drafting and review",
      "model": "openai/gpt-5.4",
      "mode": "primary"
    },
    "atlas": {
      "description": "General high-quality execution",
      "model": "vercel/anthropic/claude-sonnet-4.5",
      "mode": "primary"
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "default_agent": "sisyphus",
  "plugin": []
}

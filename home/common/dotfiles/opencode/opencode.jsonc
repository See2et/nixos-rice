{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "model": "vercel/moonshotai/kimi-k2.5",
  "instructions": [
    "AGENTS.md"
  ],
  "default_agent": "sisyphus",
  "plugin": [
    "oh-my-openagent",
    "opencode-skill-creator"
  ],
  "lsp": {},
  "mcp": {
    "miloa": {
      "type": "remote",
      "url": "http://localhost:3000/w/6a3796854921bf6f4061a1f5/mcp",
      "enabled": true,
      "timeout": 30000
    },
    "godot": {
      "type": "local",
      "command": ["npx", "@coding-solo/godot-mcp"],
      "enabled": true,
      "timeout": 30000
      // GODOT_PATH is intentionally omitted — godot-mcp auto-detects.
      // Platform reference:
      //   Darwin: /opt/homebrew/bin/godot (Homebrew cask)
      //   NixOS Desktop: godot in PATH via pkgsUnstable.godot_4_6
      //   WSL/Laptop: Godot not installed; disable if needed
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "model": "vercel/moonshotai/kimi-k2.5",
  "agent": {
    "sisyphus": {
      "description": "Default coding agent with OpenCode Go Kimi K2.6",
      "model": "opencode-go/kimi-k2.6",
      "mode": "primary"
    },
    "hephaestus": {
      "description": "Implementation-focused coding agent",
      "model": "openai/gpt-5.5",
      "mode": "primary"
    },
    "oracle": {
      "description": "Deep architecture and decision support",
      "model": "openai/gpt-5.4",
      "mode": "primary"
    },
    "librarian": {
      "description": "Research and reference-heavy tasks",
      "model": "opencode-go/qwen3.5-plus",
      "mode": "primary"
    },
    "multimodal-looker": {
      "description": "Multimodal inspection tasks",
      "model": "opencode-go/kimi-k2.6",
      "mode": "primary"
    },
    "prometheus": {
      "description": "Maximum-depth reasoning",
      "model": "opencode-go/kimi-k2.6",
      "mode": "primary"
    },
    "metis": {
      "description": "Analytical strategy and planning",
      "model": "opencode-go/glm-5.1",
      "mode": "primary"
    },
    "momus": {
      "description": "Balanced drafting and review",
      "model": "openai/gpt-5.4",
      "mode": "primary"
    },
    "atlas": {
      "description": "General high-quality execution",
      "model": "opencode-go/kimi-k2.6",
      "mode": "primary"
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "default_agent": "sisyphus",
  "plugin": [
    "oh-my-openagent"
  ],
  "lsp": true,
  "mcp": {
    "miloa": {
      "type": "remote",
      "url": "https://miloa-beta.comni.pl/w/69f1f3e11d1ab359d844ba89/mcp",
      "headers": {
        "Authorization": "Bearer dummy"
      }
    },
    "godot": {
      "type": "local",
      "command": ["npx", "@coding-solo/godot-mcp"],
      "enabled": true,
      "timeout": 30000
      // GODOT_PATH is intentionally omitted — godot-mcp auto-detects.
      // Platform reference:
      //   Darwin: /opt/homebrew/bin/godot (Homebrew cask)
      //   NixOS Desktop: godot in PATH via pkgsUnstable.godot_4_6
      //   WSL/Laptop: Godot not installed; disable if needed
    }
  }
}

{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 401, 403, 404, 429, 500, 502, 503, 504],
    "max_fallback_attempts": 5,
    "cooldown_seconds": 15,
    "timeout_seconds": 10,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "vercel/moonshotai/kimi-k2.6",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "opencode-go/glm-5.1",
        "vercel/zai/glm-5.1"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "openai/gpt-5.3-codex"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "opencode-go/glm-5.1",
        "vercel/zai/glm-5.1"
      ]
    },
    "librarian": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": [
        "opencode-go/minimax-m2.7",
        "vercel/alibaba/qwen3.5-plus",
        "vercel/minimax/minimax-m2.7-highspeed",
        "openai/gpt-5.4-mini-fast"
      ]
    },
    "explore": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": [
        "opencode-go/minimax-m2.7",
        "vercel/alibaba/qwen3.5-plus",
        "vercel/minimax/minimax-m2.7-highspeed",
        "openai/gpt-5.4-mini-fast"
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.6",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "vercel/moonshotai/kimi-k2.6",
        "vercel/zai/glm-4.6v"
      ]
    },
    "prometheus": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "high"
        },
        "vercel/moonshotai/kimi-k2.6",
        "vercel/zai/glm-5.1"
      ]
    },
    "metis": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        {
          "model": "openai/gpt-5.4",
          "variant": "high"
        },
        "vercel/zai/glm-5.1",
        "vercel/moonshotai/kimi-k2.6"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-go/glm-5.1",
        "vercel/zai/glm-5.1"
      ]
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "opencode-go/minimax-m2.7",
        "vercel/moonshotai/kimi-k2.6",
        "vercel/minimax/minimax-m2.7"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/qwen3.6-plus",
      "variant": "high",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        {
          "model": "vercel/alibaba/qwen3.6-plus",
          "variant": "high"
        },
        "vercel/google/gemini-3.1-pro-preview"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "high"
        },
        "openai/gpt-5.3-codex",
        "opencode-go/glm-5.1"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "openai/gpt-5.3-codex",
        "opencode-go/glm-5.1"
      ]
    },
    "artistry": {
      "model": "opencode-go/qwen3.6-plus",
      "variant": "high",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        {
          "model": "vercel/alibaba/qwen3.6-plus",
          "variant": "high"
        },
        "vercel/google/gemini-3.1-pro-preview"
      ]
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "opencode-go/minimax-m2.7",
        "vercel/minimax/minimax-m2.7-highspeed",
        "openai/gpt-5.4-mini-fast"
      ]
    },
    "unspecified-low": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/glm-5.1",
        "opencode-go/minimax-m2.7",
        "openai/gpt-5.4-mini",
        "vercel/moonshotai/kimi-k2.6",
        "vercel/minimax/minimax-m2.7"
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "high"
        },
        "vercel/moonshotai/kimi-k2.6",
        "vercel/zai/glm-5.1"
      ]
    },
    "writing": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        "vercel/moonshotai/kimi-k2.6",
        "vercel/google/gemini-3-flash"
      ]
    }
  },
  "background_task": {
    "providerConcurrency": {
      "openai": 3,
      "opencode-go": 10,
      "vercel": 1
    }
  },
  "git_master": {
    "include_co_authored_by": false
  }
}

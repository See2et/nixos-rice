{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 20,
    "timeout_seconds": 20,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "vercel/moonshotai/kimi-k2.6",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "opencode/gpt-5.3-codex-spark",
      "fallback_models": [
        "openai/gpt-5.4-mini-fast",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "explore": {
      "model": "opencode/gpt-5.3-codex-spark",
      "fallback_models": [
        "openai/gpt-5.4-mini-fast",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "quick": {
      "model": "opencode/gpt-5.3-codex-spark",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "writing": {
      "model": "opencode/gpt-5.3-codex-spark",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    }
  },
  "git_master": {
    "include_co_authored_by": false
  }
}

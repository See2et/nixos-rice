{
  "title": "Ghostty overrides",
  "rules": [
    {
      "description": "Ghostty: map Ctrl+H to Backspace",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": [
                "control"
              ]
            }
          },
          "to": [
            {
              "key_code": "delete_or_backspace"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
